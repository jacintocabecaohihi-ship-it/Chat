local function ShowStatusText(isOn)
    if not ExternalToggle.Visible then return end
    
    local txt = Instance.new("TextLabel", ScreenGui)
    txt.Text = isOn and "ON" or "OFF"
    txt.TextColor3 = isOn and Color3.fromRGB(50, 255, 50) or Color3.fromRGB(255, 50, 50)
    txt.BackgroundTransparency = 1
    txt.Font = Enum.Font.GothamBold
    txt.TextSize = 16
    txt.Size = UDim2.new(0, 50, 0, 20)
    
    local startY = ExternalToggle.Position.Y.Offset + (Config.extSize / 2) - 10
    txt.Position = UDim2.new(ExternalToggle.Position.X.Scale, ExternalToggle.Position.X.Offset + Config.extSize + 5, ExternalToggle.Position.Y.Scale, startY)
    
    local tween = TweenService:Create(txt, TweenInfo.new(1.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        TextTransparency = 1,
        Position = UDim2.new(txt.Position.X.Scale, txt.Position.X.Offset, txt.Position.Y.Scale, startY - 30)
    })
    
    tween:Play()
    task.delay(1.5, function() if txt then txt:Destroy() end end)
end

