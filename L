local function Fade(obj, show)
    local t = show and 0 or 1
    if show then obj.Visible = true end
    TweenService:Create(obj, TweenInfo.new(0.3), {
        BackgroundTransparency = (obj:IsA("Frame") or obj:IsA("ScrollingFrame") and (show and 0 or 1) or (show and 0.2 or 1)),
        ImageTransparency = (obj:IsA("ImageButton") and t or nil),
        TextTransparency = (obj:IsA("TextButton") or obj:IsA("TextBox") and t or nil)
    }):Play()
    if not show then task.delay(0.3, function() obj.Visible = false end) end
end

