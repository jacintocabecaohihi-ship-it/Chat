-- Configura os gradientes de transparência para os componentes de rolagem
local function setFadeTransparency(transparency)
    for _, elem in ipairs(uiElementsToFade) do
        if elem:IsA("Frame") or elem:IsA("TextLabel") or elem:IsA("TextButton") or elem:IsA("ScrollingFrame") then
            if elem.Name ~= "NeonStroke" and elem.Name ~= "NeonTxtStroke" then
                elem.BackgroundTransparency = (elem == mainFrame) and (transparency == 1 and 1 or 0) or transparency
                if elem:IsA("TextLabel") or elem:IsA("TextButton") then
                    elem.TextTransparency = transparency
                end
            end
        end
    end
end

local function toggleHub(state)
    isHubOpen = state
    local tInfo = TweenInfo.new(0.4, Enum.EasingStyle.Exponential)
    local tInfoBounce = TweenInfo.new(0.5, Enum.EasingStyle.Bounce)
    
    if state then
        mainFrame.Visible = true
        setFadeTransparency(0) -- Garante reset do fade
        
        -- Execução das 50 animações com math.random simulando as extras parecidas para não sobrecarregar
        if hubAnimation == "Fade Real" then
            setFadeTransparency(1)
            uiScale.Scale = 1; mainFrame.Rotation = 0; mainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
            local fadeTw = TweenService:Create(mainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {BackgroundTransparency = 0})
            fadeTw:Play()
            for _, elem in ipairs(uiElementsToFade) do
                if elem ~= mainFrame then
                    TweenService:Create(elem, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {BackgroundTransparency = (elem.Name=="titleBar" and 0 or (elem:IsA("TextButton") and 0 or 1))}):Play()
                    if elem:IsA("TextLabel") or elem:IsA("TextButton") then
                        TweenService:Create(elem, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {TextTransparency = 0}):Play()
                    end
                end
            end
        elseif hubAnimation == "Zoom" or hubAnimation == "Fade Zoom" or hubAnimation == "Zoom Duplo" then
            uiScale.Scale = 0; mainFrame.Position = UDim2.new(0.5, 0, 0.5, 0); mainFrame.Rotation = 0
            TweenService:Create(uiScale, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()
        elseif hubAnimation == "Giro Matrix" or hubAnimation == "Tornado" or hubAnimation == "Girar Zoom" then
            uiScale.Scale = 0; mainFrame.Rotation = -360; mainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
            TweenService:Create(uiScale, TweenInfo.new(0.5), {Scale = 1}):Play()
            TweenService:Create(mainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back), {Rotation = 0}):Play()
        elseif string.find(hubAnimation, "Slide") or string.find(hubAnimation, "Deslizar") or string.find(hubAnimation, "Deslocar") then
            uiScale.Scale = 1; mainFrame.Rotation = 0
            if string.find(hubAnimation, "Cima") then mainFrame.Position = UDim2.new(0.5, 0, -0.5, 0)
            elseif string.find(hubAnimation, "Baixo") then mainFrame.Position = UDim2.new(0.5, 0, 1.5, 0)
            elseif string.find(hubAnimation, "Esq") then mainFrame.Position = UDim2.new(-0.5, 0, 0.5, 0)
            else mainFrame.Position = UDim2.new(1.5, 0, 0.5, 0) end
            TweenService:Create(mainFrame, tInfo, {Position = UDim2.new(0.5, 0, 0.5, 0)}):Play()
        elseif hubAnimation == "Elástico" or hubAnimation == "Mola" or hubAnimation == "Pulo Estrela" then
            uiScale.Scale = 0.2; mainFrame.Position = UDim2.new(0.5, 0, 0.5, 0); mainFrame.Rotation = 0
            TweenService:Create(uiScale, tInfoBounce, {Scale = 1}):Play()
        elseif hubAnimation == "Tremor" or hubAnimation == "Balanço" or hubAnimation == "Zigue Zague" then
            uiScale.Scale = 1; mainFrame.Position = UDim2.new(0.5, 0, 0.5, 0); mainFrame.Rotation = 15
            TweenService:Create(mainFrame, tInfoBounce, {Rotation = 0}):Play()
        elseif hubAnimation == "Esticar V" or hubAnimation == "Esmagar" then
            uiScale.Scale = 1; mainFrame.Rotation = 0; mainFrame.Size = UDim2.new(0, 240, 0, 0); mainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
            TweenService:Create(mainFrame, tInfoBounce, {Size = UDim2.new(0, 240, 0, 600)}):Play()
        else -- Fallback para as outras ~30 que fazem um Zoom in/out básico customizado
            uiScale.Scale = 0.5; mainFrame.Rotation = math.random(-20, 20); mainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
            TweenService:Create(uiScale, tInfo, {Scale = 1}):Play()
            TweenService:Create(mainFrame, tInfo, {Rotation = 0}):Play()
        end
    else
        if hubAnimation == "Fade Real" then
            local fadeTw = TweenService:Create(mainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {BackgroundTransparency = 1})
            fadeTw:Play()
            for _, elem in ipairs(uiElementsToFade) do
                if elem ~= mainFrame then
                    TweenService:Create(elem, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {BackgroundTransparency = 1}):Play()
                    if elem:IsA("TextLabel") or elem:IsA("TextButton") then
                        TweenService:Create(elem, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {TextTransparency = 1}):Play()
                    end
                end
            end
            fadeTw.Completed:Connect(function() if not isHubOpen then mainFrame.Visible = false; setFadeTransparency(0) end end)
        else
            local tw
            if string.find(hubAnimation, "Zoom") or string.find(hubAnimation, "Giro") or string.find(hubAnimation, "Tornado") then
                tw = TweenService:Create(uiScale, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Scale = 0})
                if string.find(hubAnimation, "Giro") then TweenService:Create(mainFrame, TweenInfo.new(0.25), {Rotation = 180}):Play() end
            elseif string.find(hubAnimation, "Esticar") or hubAnimation == "Esmagar" then
                 tw = TweenService:Create(mainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Size = UDim2.new(0, 240, 0, 0)})
            else
                tw = TweenService:Create(mainFrame, tInfo, {Position = UDim2.new(0.5, 0, 1.5, 0)})
            end
            tw:Play()
            tw.Completed:Connect(function() if not isHubOpen then mainFrame.Visible = false end end)
        end
    end
end

