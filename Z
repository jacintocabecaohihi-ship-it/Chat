local function getFovCenter() 
    return FovPosition == "Center" and Vector2.new(camera.ViewportSize.X / 2, (camera.ViewportSize.Y / 2) - GuiService:GetGuiInset().Y - 5) or UserInputService:GetMouseLocation() 
end

local function getCorrectPart(character)
    if not character then return nil end
    if TargetPart == "Random" then
        local pT = {"Head", "UpperTorso", "LowerTorso", "HumanoidRootPart", "LeftUpperArm", "RightUpperArm", "LeftUpperLeg", "RightUpperLeg"}
        local vT = {}
        for _, n in ipairs(pT) do local p = character:FindFirstChild(n); if p and p:IsA("BasePart") then table.insert(vT, p) end end
        if #vT > 0 then return vT[math.random(1, #vT)] end
    end
    local p = character:FindFirstChild(TargetPart)
    if p and p:IsA("BasePart") then return p end
    local head = character:FindFirstChild("Head")
    if head and head:IsA("BasePart") then return head end
    return character:FindFirstChild("HumanoidRootPart")
end

local function getClosestPart()
    local closest, dist = nil, math.max(FovValue, 1)
    local fovCenter = getFovCenter()
    
    if LockMode == "LockUntilDeath" and CurrentTarget then
        local humanoid = CurrentTarget:FindFirstChild("Humanoid")
        if humanoid and humanoid.Health > 0 then
            local part = getCorrectPart(CurrentTarget)
            if part then
                local pos, onScreen = camera:WorldToViewportPoint(part.Position)
                if onScreen then return part end
            end
        else CurrentTarget = nil end
    end
    
    for _, obj in pairs(Workspace:GetChildren()) do
        local isPlayer = Players:GetPlayerFromCharacter(obj)
        if TargetType == "Players" and not isPlayer then continue end
        if TargetType == "NPCs" and isPlayer then continue end
        if obj == localPlayer.Character then continue end
        
        local humanoid = obj:FindFirstChild("Humanoid")
        if not humanoid or humanoid.Health <= 0 then continue end
        if TeamCheck and isPlayer and isPlayer.Team == localPlayer.Team then continue end
        
        local part = getCorrectPart(obj)
        if part then
            local pos, onScreen = camera:WorldToViewportPoint(part.Position)
            if onScreen then
                local mDist = (Vector2.new(pos.X, pos.Y) - fovCenter).Magnitude
                if mDist <= dist then
                    if WallCheck then
                        local params = RaycastParams.new(); params.FilterDescendantsInstances = {localPlayer.Character, obj}; params.FilterType = Enum.RaycastFilterType.Blacklist
                        local rayResult = Workspace:Raycast(camera.CFrame.Position, part.Position - camera.CFrame.Position, params)
                        if rayResult then continue end
                    end
                    dist = mDist; closest = part; CurrentTarget = obj
                end
            end
        end
    end
    return closest
end

